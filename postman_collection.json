{
  "info": {
    "name": "Geciara API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "correntistaId", "value": "" },
    { "key": "contaId", "value": "" }
  ],
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "admin", "type": "string" },
      { "key": "password", "value": "admin123", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Correntistas",
      "item": [
        {
          "name": "POST - Cadastrar Correntista",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Salvar ID', () => {",
                  "  pm.collectionVariables.set('correntistaId', pm.response.json().id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/correntistas", "host": ["{{baseUrl}}"], "path": ["api", "correntistas"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeCompleto\": \"Maria Clara Fernandes\",\n  \"endereco\": {\n    \"logradouro\": \"Rua Augusta\",\n    \"numero\": \"1578\",\n    \"complemento\": \"Apto 42\",\n    \"bairro\": \"Consolação\",\n    \"cidade\": \"São Paulo\",\n    \"uf\": \"SP\",\n    \"cep\": \"01310100\"\n  },\n  \"tipoIdentificador\": \"CPF\",\n  \"numeroIdentificador\": \"12345678909\"\n}"
            }
          }
        },
        {
          "name": "GET - Listar Todos (Resumo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('É paginado', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('content').that.is.an('array');",
                  "  pm.expect(json).to.have.property('totalElements');",
                  "  pm.expect(json).to.have.property('totalPages');",
                  "  pm.expect(json).to.have.property('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/correntistas?page=0&size=10&sort=id,asc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "correntistas"],
              "query": [
                { "key": "page", "value": "0", "description": "Número da página (0-indexed)" },
                { "key": "size", "value": "10", "description": "Tamanho da página" },
                { "key": "sort", "value": "id,asc", "description": "Ordenação" }
              ]
            }
          }
        },
        {
          "name": "GET - Listar Todos (Completos)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('É paginado com contas', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('content').that.is.an('array');",
                  "  pm.expect(json.content[0]).to.have.property('contas');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/correntistas/completos?page=0&size=10&sort=id,asc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "correntistas", "completos"],
              "query": [
                { "key": "page", "value": "0", "description": "Número da página (0-indexed)" },
                { "key": "size", "value": "10", "description": "Tamanho da página" },
                { "key": "sort", "value": "id,asc", "description": "Ordenação" }
              ]
            }
          }
        },
        {
          "name": "GET - Buscar por Identificador",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Tem contas', () => pm.expect(pm.response.json()).to.have.property('contas'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/correntistas/12345678909", "host": ["{{baseUrl}}"], "path": ["api", "correntistas", "12345678909"] }
          }
        },
        {
          "name": "PUT - Atualizar Correntista",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/correntistas/{{correntistaId}}", "host": ["{{baseUrl}}"], "path": ["api", "correntistas", "{{correntistaId}}"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeCompleto\": \"Maria Clara Fernandes da Silva\"\n}"
            }
          }
        },
        {
          "name": "DELETE - Excluir Correntista",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('204 No Content', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/correntistas/{{correntistaId}}", "host": ["{{baseUrl}}"], "path": ["api", "correntistas", "{{correntistaId}}"] }
          }
        },
        {
          "name": "PUT - Atualizar Endereço Parcial",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/correntistas/{{correntistaId}}", "host": ["{{baseUrl}}"], "path": ["api", "correntistas", "{{correntistaId}}"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"endereco\": {\n    \"logradouro\": \"Av. Paulista\",\n    \"numero\": \"1000\",\n    \"bairro\": \"Bela Vista\"\n  }\n}"
            }
          }
        },
        {
          "name": "PUT - Body Vazio (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('400 Bad Request', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/api/correntistas/{{correntistaId}}", "host": ["{{baseUrl}}"], "path": ["api", "correntistas", "{{correntistaId}}"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        },
        {
          "name": "GET - Correntista Inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('404 Not Found', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/correntistas/00000000000", "host": ["{{baseUrl}}"], "path": ["api", "correntistas", "00000000000"] }
          }
        },
        {
          "name": "POST - Cadastro Dados Inválidos (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('400 Bad Request', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/correntistas", "host": ["{{baseUrl}}"], "path": ["api", "correntistas"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeCompleto\": \"\",\n  \"endereco\": {\n    \"logradouro\": \"\",\n    \"numero\": \"\",\n    \"bairro\": \"\",\n    \"cidade\": \"\",\n    \"uf\": \"\",\n    \"cep\": \"\"\n  },\n  \"tipoIdentificador\": \"CPF\",\n  \"numeroIdentificador\": \"\"\n}"
            }
          }
        }
      ]
    },
